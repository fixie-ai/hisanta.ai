# Gemini AI Configuration
# Get your API key from: https://makersuite.google.com/app/apikey
NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# Vercel KV (for character storage)
# Automatically provided by Vercel when you add KV to your project
# KV_URL=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# KV_REST_API_READ_ONLY_TOKEN=

# Optional: LaunchDarkly (for feature flags)
NEXT_PUBLIC_LAUNCHDARKLY_CLIENT_ID=your_launchdarkly_client_id

# Optional: Datadog RUM (for monitoring)
NEXT_PUBLIC_DATADOG_APP_ID=your_datadog_app_id
NEXT_PUBLIC_DATADOG_CLIENT_TOKEN=your_datadog_client_token

# Optional: Vercel (automatically set in Vercel deployments)
NEXT_PUBLIC_VERCEL_GIT_COMMIT_SHA=
